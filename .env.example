# Tiingo API Configuration
# Get your key at https://api.tiingo.com/
TIINGO_API_KEY=your_api_key_here

# Market Configuration
TARGET_MARKET=US
ASSET_TYPE=stock
CURRENCY=USD

# Storage Configuration
# Mac Default: "/Volumes/LaCie/SMID-SEC Data Engine/storage"
# Linux example: "/mnt/lacie/storage"
LACIE_STORAGE_PATH="/Volumes/LaCie/SMID-SEC Data Engine/storage"
