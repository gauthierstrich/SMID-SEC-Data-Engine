# --- SMID-SEC Data Engine Configuration ---

# Tiingo API Key (Institutional Access)
TIINGO_API_KEY=your_tiingo_api_key_here

# --- Storage Paths (Institutional Standard) ---
# Linux Example: /media/gauthierstrich/LaCie/SMID-SEC-Data-Engine-Storage
# macOS Example: /Volumes/LaCie/SMID-SEC-Data-Engine-Storage
# Windows Example: D:/SMID-SEC-Data-Engine-Storage
# If left empty, the engine defaults to a local 'storage/' folder at root.
LACIE_STORAGE_PATH=

# SEC Requirements (Must include valid email)
SEC_USER_AGENT="Your Name (your.email@example.com)"
